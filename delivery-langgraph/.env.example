# ============================================================
#  El Trujillano Delivery — variables de entorno
#  Copia este archivo a .env y completa los valores.
# ============================================================

# --- API de Claude (Anthropic) ---
# Clave de la API de Claude. Obténla en https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
# Modelo por defecto (rápido y económico). Cubre clasificación, visión y crítico del Deep Agent.
CLAUDE_MODEL=claude-haiku-4-5-20251001

# --- Base de datos PostgreSQL 15 + pgvector ---
# Formato psycopg3 requerido por langchain-postgres. (Render entrega 'postgresql://';
# el backend lo reescribe solo a 'postgresql+psycopg://'.)
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/el_trujillano

# --- Checkpointer de LangGraph (memoria de corto plazo por sesión) ---
# "memory" (desarrollo/tests) o "postgres" (PostgresSaver sobre la misma BD, prod/Render).
LANGGRAPH_CHECKPOINTER=memory

# --- Embeddings (Claude NO tiene embeddings propios) ---
# Proveedor: "voyage" (recomendado) o "huggingface" (local, sin costo/API).
EMBEDDINGS_PROVIDER=voyage
# Si usas Voyage AI:
VOYAGE_API_KEY=pa-xxxxxxxxxxxxxxxxxxxxxxxx
VOYAGE_MODEL=voyage-3
# Si usas HuggingFace (local), modelo multilingüe ligero por defecto:
HF_EMBEDDINGS_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# --- Observabilidad LangSmith ---
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=lsv2_xxxxxxxxxxxxxxxxxxxxxxxx
LANGSMITH_PROJECT=el-trujillano-delivery
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# --- Autenticación del panel (JWT) ---
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio
JWT_EXPIRE_HOURS=8

# --- Reglas de negocio configurables ---
# Datos del titular para validar comprobantes Yape/Plin.
NUMERO_YAPE_RESTAURANTE=938749977
NOMBRE_TITULAR_PAGO=Restaurante El Trujillano
# Tope de auto-corrección del Deep Agent de reclamos.
MAX_ITERACIONES_RECLAMO=3

# --- Blindaje anti prompt-injection / control de costo (longitud de entrada) ---
MAX_INPUT_CHARS=2000
MAX_RECLAMO_CHARS=4000
